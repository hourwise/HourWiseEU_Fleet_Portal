      "step2": {
        "title": "2. Détection de conduite",
        "body": "L'app détecte la conduite via la vitesse. À l'arrêt, elle repasse en 'Travail'."
      },
      "step3": {
        "title": "3. Prendre une pause",
        "body": "Appuyez sur 'Démarrer pause'. Une pause de 45 min réinitialise le cycle de conduite de 4h30."
      },
      "step4": {
        "title": "4. Disponibilité (POA)",
